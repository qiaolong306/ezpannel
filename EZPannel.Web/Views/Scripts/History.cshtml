@model dynamic
@{
    ViewData["Title"] = "执行历史";
    var histories = (IEnumerable<EZPannel.Api.Models.ScriptHistory>)Model.Histories;
    var currentPage = (int)Model.CurrentPage;
    var totalPages = (int)Model.TotalPages;
    var totalCount = (int)Model.TotalCount;
    var pageSize = (int)Model.PageSize;
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">执行历史</h4>
            <p class="text-muted small mb-0">共 @totalCount 条记录，每页 @pageSize 条</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">脚本名称</th>
                        <th>目标服务器</th>
                        <th>执行人</th>
                        <th>执行时间</th>
                        <th class="pe-4 text-end">状态</th>
                    </tr>
                </thead>
                <tbody>
                    @if (histories != null && histories.Any())
                    {
                        @foreach (var item in histories)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-medium">@(item.Script?.Name ?? "已删除脚本")</div>
                                    <small class="text-muted">ID: @item.ScriptId</small>
                                </td>
                                <td>
                                    <div><i class="bi bi-hdd-network me-1"></i> @(item.Server?.Name ?? "未知服务器")</div>
                                    <code class="small text-muted">@(item.Server?.Host ?? "-")</code>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">@item.Executor</span>
                                </td>
                                <td>
                                    <div class="small">@item.ExecutedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
                                </td>
                                <td class="pe-4 text-end">
                                    @if (item.Success)
                                    {
                                        <span class="badge bg-success-soft text-success">
                                            <i class="bi bi-check-circle me-1"></i>成功
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-soft text-danger">
                                            <i class="bi bi-x-circle me-1"></i>失败
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-clock-history display-4 d-block mb-3 opacity-25"></i>
                                暂无执行记录
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="分页导航" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage - 1)&size=@pageSize">上一页</a>
                </li>

                @{
                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, currentPage + 2);
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i&size=@pageSize">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage + 1)&size=@pageSize">下一页</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    .pagination .active .page-link {
        z-index: 3;
        color: #fff;
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>