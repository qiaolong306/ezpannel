@model EZPannel.Api.Models.User
@{
    ViewData["Title"] = "个人信息";
    ViewData["ActiveMenu"] = "profile";
}

<div class="container-fluid p-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4 text-center border-bottom bg-light">
                    <img src="https://cube.elemecdn.com/0/88/03b0d39583f48206768a7534e55bcpng.png" class="rounded-circle mb-3" style="width: 80px; border: 3px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                    <h4 class="fw-bold mb-1">@Model.Username</h4>
                    <span class="badge bg-primary px-3 rounded-pill">@Model.Role</span>
                </div>
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i>安全设置</h6>
                    <form id="profileForm">
                        <div class="mb-3">
                            <label class="form-label small text-muted">当前用户</label>
                            <input type="text" class="form-control bg-light" value="@Model.Username" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">新密码</label>
                            <input type="password" id="newPassword" class="form-control" placeholder="留空则不修改">
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-muted">确认新密码</label>
                            <input type="password" id="confirmPassword" class="form-control" placeholder="请再次输入新密码">
                        </div>
                        <button type="button" class="btn btn-primary w-100 py-2 fw-bold" onclick="updateProfile()">
                            <i class="bi bi-save me-1"></i> 保存修改
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function updateProfile() {
        const newPass = document.getElementById('newPassword').value;
        const confirmPass = document.getElementById('confirmPassword').value;

        if (!newPass) {
            alert('请输入新密码');
            return;
        }

        if (newPass !== confirmPass) {
            alert('两次输入的密码不一致');
            return;
        }

        try {
            const formData = new FormData();
            formData.append('id', @Model.Id);
            formData.append('newPassword', newPass);
            await axios.post('/Users/UpdatePassword', formData);
            alert('密码修改成功，请重新登录');
            location.href = '/Auth/Logout';
        } catch (e) {
            alert('更新失败: ' + (e.response?.data || e.message));
        }
    }
</script>
}