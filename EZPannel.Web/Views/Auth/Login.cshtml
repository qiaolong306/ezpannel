@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登录 - EZPannel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #6a82fb, #fc5c7d); height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { width: 400px; padding: 40px; border-radius: 12px; background: rgba(255, 255, 255, 0.9); box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        .login-title { text-align: center; margin-bottom: 30px; color: #333; font-weight: bold; }
        .btn-primary { background: linear-gradient(135deg, #6a82fb, #fc5c7d); border: none; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2 class="login-title">EZPannel 登录</h2>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
        }
        <form method="post" action="/Auth/Login">
            <div class="mb-3">
                <label class="form-label">用户名</label>
                <input type="text" name="username" class="form-control" required placeholder="请输入用户名">
            </div>
            <div class="mb-4">
                <label class="form-label">密码</label>
                <input type="password" name="password" class="form-control" required placeholder="请输入密码">
            </div>
            <div class="mb-4">
                <label class="form-label">验证码</label>
                <div class="input-group">
                    <input type="text" name="code" class="form-control" required placeholder="请输入验证码">
                    <img src="/Auth/Code" alt="验证码" class="img-thumbnail" style="cursor: pointer;" onclick="this.src='/Auth/Code?'+new Date().getTime()">
                </div>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary">登录</button>
            </div>
        </form>
    </div>
    <script>
        // Clear old tokens
        localStorage.removeItem('token');
        document.cookie = "access_token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
    </script>
</body>
</html>
