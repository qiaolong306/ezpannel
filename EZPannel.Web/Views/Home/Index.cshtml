@{
    ViewData["Title"] = "服务器列表";
    ViewData["ActiveMenu"] = "servers";
}
<style>
    .server-card { transition: all 0.3s cubic-bezier(.25,.8,.25,1); border: none; border-radius: 12px; overflow: hidden; background: #fff; }
    .server-card:hover { transform: translateY(-5px); box-shadow: 0 14px 28px rgba(0,0,0,0.1), 0 10px 10px rgba(0,0,0,0.08) !important; }
    .card-header-top { height: 6px; width: 100%; }
    .bg-windows { background: #0078d7; }
    .bg-linux { background: #f04e23; }
    
    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; }
    .dot-online { background-color: #67c23a; box-shadow: 0 0 8px #67c23a; }
    .dot-offline { background-color: #909399; }
    
    .server-host { font-size: 12px; color: #909399; font-family: monospace; }
    .usage-label { font-size: 12px; color: #606266; margin-bottom: 4px; display: flex; justify-content: space-between; }
    .usage-val { font-weight: bold; color: #303133; }
    
    .btn-action { width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; transition: 0.2s; border: 1px solid #ebeef5; background: #fff; color: #606266; }
    .btn-action:hover { background: #f5f7fa; color: var(--primary-color); border-color: var(--primary-color); }
    .btn-action-danger:hover { color: #f56c6c; border-color: #f56c6c; }
    
    .empty-state { padding: 80px 0; text-align: center; color: #909399; }
    .empty-state i { font-size: 48px; display: block; margin-bottom: 15px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">服务器概览</h2>
        <p class="text-muted small mb-0">实时监控集群状态与性能指标</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" onclick="event.stopPropagation(); fetchServers()">
            <i class="bi bi-arrow-clockwise"></i> 刷新
        </button>
        <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#addServerModal" onclick="event.stopPropagation()">
            <i class="bi bi-plus-lg me-1"></i> 添加服务器
        </button>
    </div>
</div>

<div id="serverList" class="row g-4">
</div>

<!-- Add Server Modal -->
<div class="modal fade" id="addServerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">添加服务器</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addServerForm">
                    <div class="mb-3">
                        <label class="form-label">名称</label>
                        <input type="text" class="form-control" name="name" placeholder="如：测试服务器" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">主机</label>
                        <input type="text" class="form-control" name="host" placeholder="IP 或 域名" required>
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">端口</label>
                            <input type="number" class="form-control" name="port" value="22" required>
                        </div>
                        <div class="col">
                            <label class="form-label">系统</label>
                            <select class="form-select" name="operatingSystem">
                                <option value="Linux">Linux</option>
                                <option value="Windows">Windows</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">用户名</label>
                        <input type="text" class="form-control" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">密码</label>
                        <input type="password" class="form-control" name="password" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-info" onclick="testConnection()">测试连接</button>
                <button type="button" class="btn btn-primary" onclick="saveServer()">保存</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function fetchServers() {
        try {
            // 1. Quick load
            const quickRes = await axios.get('/Servers?quick=true');
            renderServers(quickRes.data);
                    for (const server of quickRes.data) {
                                    //拉取状态
                    const statusRes = await axios.get('/Servers/' + server.id + '/status');
                    renderServerStatus(server, statusRes.data);
            }
        } catch (err) {
            console.error('Failed to fetch servers', err);
        }
    }

        function renderServerStatus(server, status) {
            // 找到对应的服务器卡片
            const card = document.getElementById(`server-card-${server.id}`);
            if (!card) {
                console.warn(`Server card not found for server ${server.id}`);
                return;
            }
                    // 更新状态显示
                    const statusDot = card.querySelector('.status-dot');
                    const statusText = card.querySelector('#server-statusText');
                    const isOnline = status.isOnline;
                    if (isOnline) {
                        statusDot.className = 'status-dot dot-online';
                        statusText.textContent = '在线';
                        // 更新CPU、内存和磁盘使用情况
                        const usageValues = card.querySelectorAll('.usage-val');
                        const progressBars = card.querySelectorAll('.progress-bar');

                        if (usageValues.length >= 3 && progressBars.length >= 3) {
                            // CPU
                            usageValues[0].textContent = status.cpuUsage + '%';
                            progressBars[0].style.width = status.cpuUsage + '%';
                            progressBars[0].className = `progress-bar ${status.cpuUsage > 80 ? 'bg-danger' : status.cpuUsage > 50 ? 'bg-warning' : 'bg-success'}`;

                            // 内存
                            usageValues[1].textContent = status.memUsage + '%';
                            progressBars[1].style.width = status.memUsage + '%';
                            progressBars[1].className = `progress-bar ${status.memUsage > 80 ? 'bg-danger' : status.memUsage > 50 ? 'bg-warning' : 'bg-primary'}`;

                            // 磁盘
                            usageValues[2].textContent = (status.diskUsage || 0) + '%';
                            progressBars[2].style.width = (status.diskUsage || 0) + '%';
                            progressBars[2].className = `progress-bar ${(status.diskUsage || 0) > 80 ? 'bg-danger' : (status.diskUsage || 0) > 50 ? 'bg-warning' : 'bg-info'}`;
                        }

                        // 启用按钮
                        const buttons = card.querySelectorAll('button');
                        buttons.forEach(btn => {
                            if (!btn.classList.contains('btn-action-danger')) {
                                btn.removeAttribute('disabled');
                                btn.classList.remove('btn-secondary');
                                btn.classList.add('btn-success');
                            }
                        });
                    } else {
                        statusDot.className = 'status-dot dot-offline';
                        statusText.textContent = '离线';

                        // 禁用按钮
                        const buttons = card.querySelectorAll('button');
                        buttons.forEach(btn => {
                            if (!btn.classList.contains('btn-action-danger')) {
                                btn.setAttribute('disabled', 'disabled');
                                btn.classList.remove('btn-success');
                                btn.classList.add('btn-secondary');
                            }
                        });
                    }
                    

        }

    function renderServers(servers) {
        const container = document.getElementById('serverList');
        if (servers.length === 0) {
            container.innerHTML = `
                <div class="col-12 empty-state">
                    <i class="bi bi-inbox"></i>
                    <p>暂无服务器，请点击右上角添加</p>
                </div>`;
            return;
        }

        container.innerHTML = servers.map(server => {
            const osClass = server.operatingSystem === 'Windows' ? 'bg-windows' : 'bg-linux';
            const osIcon = server.operatingSystem === 'Windows' ? 'bi-windows' : 'bi-ubuntu';
            
            return `
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div id="server-card-${server.id}" class="card server-card shadow-sm h-100">
                    <div class="card-header-top ${osClass}"></div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1 text-truncate" style="max-width: 150px">${server.name}</h5>
                                <div class="server-host">${server.host}:${server.port}</div>
                            </div>
                            <i class="bi ${osIcon} fs-4 text-muted"></i>
                        </div>

                        <div class="mb-3">
                            <div class="usage-label">
                                <span>CPU</span>
                                <span class="usage-val">--</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-light" style="width: 0%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="usage-label">
                                <span>内存</span>
                                <span class="usage-val">--</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-light" style="width: 0%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="usage-label">
                                <span>磁盘</span>
                                <span class="usage-val">--</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-light" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 px-4 py-3 d-flex justify-content-between align-items-center">
                        <div class="small">
                            <span class="status-dot dot-offline"></span>
                            <span id="server-statusText" class="text-muted">数据拉取中...</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-secondary px-3" title="进入管理" onclick="window.open('/Server/Index?serverId=${server.id}', '_blank')" disabled>
                                <i class="bi bi-box-arrow-in-right me-1"></i>进入
                            </button>
                            <button class="btn-action" title="打开终端" onclick="event.stopPropagation(); openFloatingTerminal(${server.id}, '${server.name}')" disabled>
                                <i class="bi bi-terminal"></i>
                            </button>
                            <button class="btn-action btn-action-danger" title="删除" onclick="deleteServer(${server.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `}).join('');
    }

    async function saveServer() {
        const form = document.getElementById('addServerForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.port = parseInt(data.port);

        try {
            await axios.post('/Servers', data);
            bootstrap.Modal.getInstance(document.getElementById('addServerModal')).hide();
            form.reset();
            fetchServers();
        } catch (err) {
            alert('保存失败: ' + (err.response?.data?.message || err.message));
        }
    }

    async function testConnection() {
        const form = document.getElementById('addServerForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.port = parseInt(data.port);

        try {
            await axios.post('/Servers/test-connection', data);
            alert('连接成功');
        } catch (err) {
            alert('连接失败: ' + (err.response?.data?.message || err.message));
        }
    }

    async function deleteServer(id) {
        if (!confirm('确定要删除吗？')) return;
        try {
            await axios.delete('/Servers/' + id);
            fetchServers();
        } catch (err) {
            alert('删除失败');
        }
    }

    function openTerminal(id) {
        window.location.href = `/Home/Detail/${id}?tab=terminal`;
    }

    document.addEventListener('DOMContentLoaded', fetchServers);
</script>
@{await Html.RenderPartialAsync("../Shared/_FloatingTerminal");}
}